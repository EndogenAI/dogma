{
    "chat.tools.terminal.autoApprove": {
        "gh": true,
        "git checkout": true,
        "git add": true,
        "git commit": true,
        "git push": true,
        "uv": true,
        "sed -n": true,
        "python scripts/fetch_source.py": true,
        "python scripts/validate_synthesis.py": true,
        "source .venv/bin/activate": true,
        "diff": true,
        "wait": true,
        "git stash": true,
        "git pull": true,
        "exit": true,
        "test": true,
        "awk": true,
        "git fetch": true,
        "uniq": true,
        "git check-ignore": true,
        "git remote": true,
        "timeout": true
    },
    "yaml.schemas": {
        ".vscode/agent-frontmatter.schema.json": [
            ".github/agents/*.agent.md",
            ".github/skills/*/SKILL.md"
        ]
    },
    "markdown.validate.enabled": true,
    "markdown.validate.ignoreLinkToSection": true,
    "[markdown]": {
        "files.exclude": {
            "**/*.agent.md": false
        }
    },
    "problems.exclude": {
        "**/.github/agents/*.agent.md": {
            "pattern": "Attribute 'governs' is not supported"
        },
        "**/.github/agents/executive-orchestrator.agent.md": {
            "pattern": "Unknown tool 'dogma-governance/"
        }
    }
}