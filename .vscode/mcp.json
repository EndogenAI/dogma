{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    },
    "dogma-governance": {
      "command": "uv",
      "args": ["run", "python", "-m", "mcp_server.dogma_server"],
      "cwd": "${workspaceFolder}"
    }
  }
}
